# =============================================================================
# StadiumIQ — Environment Template
# Copy this file to `.env.local` and fill in the values. NEVER commit `.env`/`.env.local`.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# The Gemini key MUST NOT be public — it is used only in server code.
# =============================================================================

# --- REQUIRED ---------------------------------------------------------------
# Google Gemini API key (free tier). Get one at https://aistudio.google.com/apikey
# Server-only. Do NOT prefix with NEXT_PUBLIC_.
GEMINI_API_KEY=

# --- OPTIONAL: model overrides (defaults are free-tier Flash models) --------
AI_MODEL_BALANCED=gemini-2.5-flash
AI_MODEL_FAST=gemini-2.5-flash-lite

# --- OPTIONAL: runtime tuning -----------------------------------------------
# Max output tokens cap for AI responses (keeps latency/cost low).
AI_MAX_OUTPUT_TOKENS=1024
# Per-session AI requests allowed per minute (rate limiting).
RATE_LIMIT_PER_MINUTE=20
# TTL (seconds) for the in-memory grounded-query cache.
GROUNDING_CACHE_TTL_SECONDS=300
# Comma-separated origins allowed to POST to AI routes (CSRF hardening).
# Defaults to localhost:3000 when unset; set to your deployed URL in production.
# ALLOWED_ORIGINS=https://stadiumiq.vercel.app

# --- OPTIONAL: app config ---------------------------------------------------
# Public site URL (used for metadata / canonical links). Safe to expose.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Log level: debug | info | warn | error
LOG_LEVEL=info
# Node environment (usually set automatically by Next.js).
# NODE_ENV=development
